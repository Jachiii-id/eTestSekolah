rules_version = '2';

// ⚠ Firestore-only authentication (no Firebase Auth).
// There is no request.auth in this app at all, so these rules cannot verify
// *who* is asking — only *what shape* of request is being made. That is a
// deliberate, explicitly-accepted trade-off (see project conversation) in
// exchange for skipping Firebase Auth setup. Concretely:
//   - `students` / `admins`: get-only, list disabled — a client can fetch
//     one doc by a username it already knows (that's how login works) but
//     cannot enumerate/dump the whole roster of usernames+passwords+tokens
//     in a single query.
//   - `results` (and its subcollections) and `settings/testConfig`: fully
//     open read/write. This is unavoidable under this model because the
//     admin dashboard needs to `list` every student's result, and there is
//     no way to distinguish "the admin dashboard" from "any other visitor"
//     without an auth token. Anyone with the deployed URL can read every
//     student's score/status/violations via the Firestore SDK directly, and
//     — since nothing can verify identity — could in principle also write
//     to another student's result doc from devtools.
// To close this gap later, the fix is to reintroduce Firebase Auth (the
// app's git history has a version wired for it) or move result writes
// behind a Cloud Function.

service cloud.firestore {
  match /databases/{database}/documents {

    match /students/{username} {
      allow get: if true;
      allow list: if false;
      allow write: if false; // only the Admin SDK seed script writes here
    }

    match /admins/{username} {
      allow get: if true;
      allow list: if false;
      allow write: if false; // only the Admin SDK seed script writes here
    }

    match /settings/testConfig {
      allow read, write: if true;
    }

    match /results/{studentId} {
      allow read, write: if true;

      match /answers/{questionNumber} {
        allow read, write: if true;
      }

      match /violations/{violationId} {
        allow read, create: if true;
        allow update, delete: if false; // keep the audit log append-only
      }
    }
  }
}
