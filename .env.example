# Firebase web app config (safe to expose client-side — restrict via Firebase Security Rules, not secrecy)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Used only by scripts/seed.ts (Firebase Admin SDK, never bundled to the client)
# Path to a Firebase service account JSON key file. Keep this file out of git.
SEED_SERVICE_ACCOUNT_PATH=./service-account.json

# Optional — otherwise the seed script defaults to username "admin" and
# generates a random password, printed once (only on first run; an existing
# admins/{username} doc is left alone on later runs).
SEED_ADMIN_USERNAME=
SEED_ADMIN_PASSWORD=
